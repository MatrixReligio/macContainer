    "Automatic installation is off until you opt in." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatic installation is off until you opt in."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "明示的に有効にするまで自動インストールは行われません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "직접 사용 설정하기 전까지 자동 설치는 꺼져 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在你主动启用前，自动安装保持关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在你主動啟用前，自動安裝會保持關閉。"
