    "parameter.builder.start.memory.detail" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Purpose: configures Memory. Upstream default: see the embedded Apple contract. Accepted values or format: positive byte count with optional unit suffix; validation grammar: ^[1-9][0-9]*[KkMmGgTtPp]?[Bb]?$. Repeat and order behavior: follows the embedded cardinality and preserves user order. Dependencies and conflicts: enforced from the reviewed contract before dispatch. OS, hardware, and runtime limits: macOS 26, Apple silicon, Apple container 1.1.0. Security or data impact: mutating; required: false. Example: choose a reviewed value in this field. Recovery: correct the highlighted value and retry; MacContainer never applies an invalid value."
          }
