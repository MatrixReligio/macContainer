    "Advanced controls remain one click away and preserve every value you entered." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Advanced controls remain one click away and preserve every value you entered."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "詳細設定はいつでも1クリックで開け、入力した値はすべて保持されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "고급 제어는 언제든 한 번의 클릭으로 열 수 있으며 입력한 모든 값을 유지합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "高级控制始终只需一次点击，并会保留你输入的所有值。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "進階控制隨時只需按一下，並會保留你輸入的所有值。"
