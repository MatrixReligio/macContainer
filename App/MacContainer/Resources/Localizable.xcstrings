    "parameter.images.pull.progressStyle.concise" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configure Progress Style using the reviewed Apple container contract."
          }
        },
        "ja" : {
          "stringUnit" : {
