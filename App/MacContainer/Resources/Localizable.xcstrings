    },
    "parameter.kernel.set.architecture.detail" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Purpose: configures Architecture. Upstream default: see the embedded Apple contract. Accepted values or format: amd64, arm64; validation grammar: ^(amd64|arm64)$. Repeat and order behavior: follows the embedded cardinality and preserves user order. Dependencies and conflicts: enforced from the reviewed contract before dispatch. OS, hardware, and runtime limits: macOS 26, Apple silicon, Apple container 1.1.0. Security or data impact: privileged; required: false. Example: choose a reviewed value in this field. Recovery: correct the highlighted value and retry; MacContainer never applies an invalid value."
          }
        },
        "ja" : {
