    "Administrator approval appears only after download, signature verification, and review." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Administrator approval appears only after download, signature verification, and review."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ダウンロード、署名検証、確認が完了した後にのみ管理者の承認を求めます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다운로드, 서명 검증, 검토가 끝난 후에만 관리자 승인을 요청합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅在完成下载、签名验证和检查后才会请求管理员批准。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有在完成下載、簽章驗證和檢查後才會要求管理員核准。"
          }
        }
      }
    },
    "Administrator approval is requested only when an install or upgrade actually begins." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Administrator approval is requested only when an install or upgrade actually begins."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インストールまたはアップグレードを実際に開始するときだけ管理者の承認を求めます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "설치 또는 업그레이드가 실제로 시작될 때만 관리자 승인을 요청합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅在安装或升级真正开始时才会请求管理员批准。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有在安裝或升級實際開始時才會要求管理員核准。"
          }
        }
      }
    },
    "Administrator approval is requested only when installation begins." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Administrator approval is requested only when installation begins."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インストール開始時にのみ管理者の承認を求めます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "설치가 시작될 때만 관리자 승인을 요청합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅在安装开始时才会请求管理员批准。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有在安裝開始時才會要求管理員核准。"
