    "A clear cause, a redacted diagnostic, and safe next actions — without exposing credentials." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A clear cause, a redacted diagnostic, and safe next actions — without exposing credentials."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "認証情報を公開せず、明確な原因、秘匿化された診断、安全な次の操作を示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자격 증명을 노출하지 않고 명확한 원인, 삭제 처리된 진단, 안전한 다음 조치를 제공합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提供明确原因、已脱敏诊断和安全的后续操作，不暴露凭据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提供明確原因、已遮蔽診斷和安全的後續操作，不會洩漏憑證。"
          }
        }
      }
    },
