{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://container.matrixreligio.com/schemas/compatibility-catalog-v1.json",
  "title": "MacContainer embedded compatibility catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "revision", "generatedAt", "entries", "updateURL"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "updateURL": { "type": "null" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "runtimeVersion", "package", "minimumAppVersion", "maximumAppVersion",
          "adapterPackageVersion", "capabilityIDs", "minimumMacOSMajor",
          "requiredHardwareCapabilities", "storageMigration", "rollback",
          "allowedUpgradeSources", "requiredProbeIDs", "attestation",
          "supersedesBlockedAttestationIDs"
        ]
      }
    }
  }
}
